{
  "author": "Jonas Thelemann",
  "description": "TrapParty's website.",
  "devDependencies": {
    "@dargmuesli/nuxt-cookie-control": "9.1.30",
    "@dargmuesli/nuxt-vio": "21.0.11",
    "@graphql-codegen/cli": "7.1.3",
    "@graphql-codegen/client-preset": "6.0.1",
    "@graphql-codegen/typescript": "6.0.2",
    "@graphql-codegen/typescript-urql-graphcache": "4.0.2",
    "@graphql-codegen/urql-introspection": "4.0.1",
    "@graphql-typed-document-node/core": "3.2.0",
    "@iconify-json/heroicons": "1.2.3",
    "@nuxt/fonts": "0.14.0",
    "@pinia/nuxt": "0.11.3",
    "@takumi-rs/core": "1.8.6",
    "@types/color": "4.2.1",
    "@types/lodash-es": "4.17.12",
    "@urql/core": "6.0.2",
    "@urql/devtools": "2.0.3",
    "@urql/exchange-graphcache": "9.0.1",
    "@urql/vue": "2.1.1",
    "@vuelidate/core": "2.0.3",
    "@vuelidate/validators": "2.0.4",
    "chart.js": "4.5.1",
    "color": "5.0.3",
    "consola": "3.4.2",
    "defu": "6.1.7",
    "eslint": "10.5.0",
    "graphql": "17.0.1",
    "lodash-es": "4.18.1",
    "nuxt": "4.4.8",
    "nuxt-security": "2.6.0",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "rainbowvis.js": "1.1.1",
    "serve": "14.2.6",
    "sharp": "0.35.1",
    "stylelint": "17.13.0",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-no-unsupported-browser-features": "8.1.1",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "ufo": "1.6.4",
    "unplugin-icons": "23.0.1",
    "unplugin-vue-components": "32.1.0",
    "vue": "3.5.38",
    "vue-chartjs": "5.3.3",
    "vue-router": "5.1.0",
    "vue-tsc": "3.3.5"
  },
  "engines": {
    "node": "24"
  },
  "name": "trapparty",
  "private": true,
  "scripts": {
    "build": "pnpm run build:node",
    "build:node": "nuxt build",
    "build:static": "nuxt generate",
    "build:static:test": "NUXT_PUBLIC_VIO_IS_TESTING=true pnpm run build:static",
    "certificates": ".config/certificates/mkcert.sh",
    "dev": "pnpm run start:dev",
    "generate": "pnpm run build:static",
    "gql:codegen": "NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\" graphql-codegen --config .config/codegen/.rc.dev.ts",
    "gql:codegen:prod": "graphql-codegen --config .config/codegen/.rc.prod.ts",
    "lint": "pnpm run lint:js && pnpm run lint:ts && pnpm run lint:style",
    "lint:fix": "pnpm run lint:js --fix && pnpm run lint:ts --fix && pnpm run lint:style --fix",
    "lint:js": "eslint --cache",
    "lint:style": "stylelint --cache \"**/*.{vue,css}\" --ignore-path .gitignore",
    "lint:ts": "nuxt typecheck",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "start": "pnpm run start:node",
    "start:dev": "pnpm run certificates && NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\" nuxt dev",
    "start:node": "node node/server/node.mjs",
    "start:static": "node node/server/static.mjs"
  },
  "type": "module",
  "version": "4.4.11"
}
